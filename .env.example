ENV=production
DOMAIN=example.com

MYSQL_DATABASE=team_signup
MYSQL_USER=team_signup
MYSQL_PASSWORD=change_this_mysql_password
MYSQL_ROOT_PASSWORD=change_this_root_password
DATABASE_URL=mysql+pymysql://team_signup:change_this_mysql_password@mysql:3306/team_signup?charset=utf8mb4

REDIS_URL=redis://redis:6379/0

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE_MINUTES=43200

WECHAT_APPID=your_wechat_miniapp_appid
WECHAT_SECRET=your_wechat_miniapp_secret
WECHAT_MOCK_LOGIN=false

DEFAULT_TEAM_NAME=业余足球队
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password
