<view class="page">
  <view class="card">
    <view class="title">提交入队申请</view>
    <view class="field-label">姓名</view>
    <view class="field-hint">请输入真实姓名</view>
    <textarea class="form-input" auto-height="{{false}}" maxlength="20" value="{{form.name}}" data-field="name" bindinput="onInput" />
    <view class="field-label">手机号</view>
    <view class="field-hint">请输入联系电话</view>
    <textarea class="form-input" auto-height="{{false}}" maxlength="20" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    <view class="field-label">场上位置</view>
    <view class="field-hint">前锋 / 中场 / 后卫 / 门将</view>
    <textarea class="form-input" auto-height="{{false}}" maxlength="20" value="{{form.position}}" data-field="position" bindinput="onInput" />
    <view class="field-label">球衣号码</view>
    <view class="field-hint">请输入常用号码</view>
    <textarea class="form-input" auto-height="{{false}}" maxlength="10" value="{{form.jersey_number}}" data-field="jersey_number" bindinput="onInput" />
    <view class="field-label">备注</view>
    <view class="field-hint">可填写想说的话</view>
    <textarea class="form-textarea" value="{{form.message}}" data-field="message" bindinput="onInput" />
    <button class="primary" bindtap="submit">提交申请</button>
  </view>
</view>
