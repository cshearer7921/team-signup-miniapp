.field-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #172033;
  margin: 26rpx 0 6rpx;
  line-height: 1.45;
}

.field-hint {
  font-size: 26rpx;
  color: #8a93a3;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.form-input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  min-height: 84rpx;
  max-height: 84rpx;
  line-height: 1.5;
  padding: 18rpx 22rpx;
  margin: 0;
  font-size: 30rpx;
  color: #172033;
  background: #fff;
  border: 1rpx solid #cbd3df;
  border-radius: 10rpx;
}

.form-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 220rpx;
  line-height: 1.5;
  padding: 24rpx 22rpx;
  margin: 0 0 28rpx;
  font-size: 30rpx;
  color: #172033;
  background: #fff;
  border: 1rpx solid #cbd3df;
  border-radius: 10rpx;
}
