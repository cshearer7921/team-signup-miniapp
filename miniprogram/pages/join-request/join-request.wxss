.field-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #172033;
  margin: 24rpx 0 10rpx;
  line-height: 42rpx;
}

.form-input {
  box-sizing: border-box;
  width: 100%;
  height: 104rpx;
  min-height: 104rpx;
  line-height: normal;
  padding: 18rpx 22rpx;
  margin: 0;
  font-size: 32rpx;
  color: #172033;
  background: #fff;
  border: 1rpx solid #cbd3df;
  border-radius: 10rpx;
}

.form-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 220rpx;
  line-height: 42rpx;
  padding: 20rpx 22rpx;
  margin: 0 0 28rpx;
  font-size: 30rpx;
  color: #172033;
  background: #fff;
  border: 1rpx solid #cbd3df;
  border-radius: 10rpx;
}

.form-placeholder {
  color: #9aa3af;
  font-size: 32rpx;
  line-height: normal;
}
