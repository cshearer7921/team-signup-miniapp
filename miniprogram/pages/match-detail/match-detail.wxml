<view class="detail-page">
  <view class="hero-card">
    <view class="hero-title">{{match.title || '活动报名'}}</view>
    <view class="info-row">
      <text class="info-icon">▦</text>
      <text>{{displayTime}}</text>
      <text class="view-count">◎ {{signupStats.total}}</text>
    </view>
    <view class="info-row">
      <text class="info-icon">◎</text>
      <text>{{match.location || '活动地点待定'}}</text>
      <text class="side-link">场地导航›</text>
    </view>
    <view class="info-row">
      <text class="info-icon">◇</text>
      <text>足球/平台可见</text>
    </view>
    <view class="info-row">
      <text class="info-icon">¥</text>
      <text>收费：自定义收费</text>
    </view>
    <view class="organizer-row">
      <view class="avatar small">{{organizerInitial}}</view>
      <view>
        <view class="organizer-name">{{organizerName}}</view>
        <view class="stars">★★★★★</view>
      </view>
    </view>
    <view class="desc">{{match.description || '云桥FC活动，暂定，看人数'}}</view>
  </view>

  <view class="signup-panel">
    <view class="stats-tabs">
      <view class="stats-tab active">报名 <text>{{signupStats.signed_up}}/{{match.capacity || '不限'}}</text></view>
      <view class="stats-tab">待定 <text>{{signupStats.maybe}}</text></view>
      <view class="stats-tab">请假 <text>{{signupStats.leave}}</text></view>
      <view class="stats-tab">出勤 <text>{{signupStats.signed_up}}</text></view>
      <view class="tab-arrow">›</view>
    </view>

    <view class="member-grid">
      <view wx:for="{{displayMembers}}" wx:key="key" class="member-card">
        <view class="avatar">{{item.initial}}</view>
        <view class="member-name">{{item.name}}</view>
        <view class="member-badge {{item.status}}">{{item.statusText}}</view>
      </view>
    </view>
  </view>

  <view class="follow-row">
    <text>关注「云桥FC」服务号，接收活动变更消息！</text>
    <text class="follow-link">马上关注</text>
  </view>

  <view class="status-card" wx:if="{{match.status !== 'open'}}">
    <view class="status-title">活动/比赛已完成</view>
    <view class="muted">开始时间超过 2 小时后，系统会自动标记为已完成。</view>
  </view>

  <view class="bottom-safe"></view>
  <view class="bottom-bar" wx:if="{{match.status === 'open'}}">
    <button class="bottom-button maybe" bindtap="chooseMaybeOrLeave">待定/请假</button>
    <button class="bottom-button signup" bindtap="signup" data-status="signed_up">报名</button>
  </view>
</view>
