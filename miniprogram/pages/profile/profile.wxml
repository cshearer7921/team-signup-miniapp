<view class="page">
  <view class="card" wx:if="{{!token}}">
    <view class="title">未登录</view>
    <button class="primary" bindtap="goLogin">去登录</button>
  </view>
  <view class="card" wx:else>
    <view class="title">我的状态</view>
    <view class="muted">审核状态：{{me.member_status || '未申请'}}</view>
    <view class="muted">角色：{{me.role || '-'}}</view>
    <button class="primary" bindtap="goJoin">入队申请</button>
    <button class="plain" bindtap="logout">退出登录</button>
  </view>
</view>
