page {
  background: #fff5f5;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: #fff;
  border: 1rpx solid #f2d6d6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #6b7280;
  font-size: 26rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.primary {
  background: #d92d20;
  color: #fff;
}

.danger {
  background: #d92d20;
  color: #fff;
}

.plain {
  background: #fff1f1;
  color: #172033;
}

input,
textarea {
  box-sizing: border-box;
  width: 100%;
  background: #fff;
  border: 1rpx solid #e7bcbc;
  border-radius: 8rpx;
  padding: 18rpx;
  margin: 12rpx 0;
}

.empty {
  text-align: center;
  color: #8a93a3;
  padding: 54rpx 0 28rpx;
}
